<Window x:Class="GraduationProject.Ordinary.Patrols"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraduationProject.Ordinary"
        mc:Ignorable="d"
        Icon="/Images/Logo.png"
        Title="ГИБДД: Патрулирования" Height="1000" Width="1900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" ResizeMode="CanMinimize">
    <Grid>
        <DataGrid FontSize="16"
          CanUserAddRows="False"
          Name="data_grid_patrols"
          AutoGenerateColumns="True"
          ColumnWidth="Auto"
          RowHeight="35"
          HeadersVisibility="Column"
          RowHeaderWidth="0"
          BorderThickness="0"
          GridLinesVisibility="All"
          CanUserResizeColumns="True"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          Margin="0,0,-18,102">
            <DataGrid.Background>
                <ImageBrush ImageSource="/Images/Background.jpg"/>
            </DataGrid.Background>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
        <Button Content="Назад" Click="Button_Click_back" FontSize="24" HorizontalAlignment="Left" Margin="42,0,0,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <TextBlock Text="Поиск:"
           FontSize="24"
           HorizontalAlignment="Left"
           Margin="240,0,0,48"
           VerticalAlignment="Bottom"/>

        <TextBox Name="TextBox_search"
         TextChanged="TextBox_search_TextChanged"
         FontSize="24"
         HorizontalAlignment="Left"
         Margin="330,0,0,44"
         VerticalAlignment="Bottom"
         Height="40"
         Width="480"
         VerticalContentAlignment="Center"/>
        <ComboBox Name="ComboBox_export"
                  SelectionChanged="ComboBox_export_SelectionChanged"
                  FontSize="24"
                  HorizontalAlignment="Right"
                  Margin="0,0,160,31"
                  VerticalAlignment="Bottom"
                  Height="66"
                  Width="171"
                  SelectedIndex="0"
                  VerticalContentAlignment="Center"
                  HorizontalContentAlignment="Center">
            <ComboBoxItem Content="Вывод" IsEnabled="False"/>
            <ComboBoxItem Content="Excel"/>
            <ComboBoxItem Content="PDF"/>
        </ComboBox>
    </Grid>
</Window>
